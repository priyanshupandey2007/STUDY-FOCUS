<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudyFocus | Student Productivity Companion</title>
     <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #4f46e5;
            --secondary: #10b981;
            --accent: #f59e0b;
            --dark: #1e293b;
            --light: #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f1f5f9;
            color: var(--dark);
        }

        .gradient-bg {
            background: linear-gradient(135deg, var(--primary) 0%, #7c3aed 100%);
        }

        .progress-ring__circle {
            transition: stroke-dashoffset 0.5s;
            transform: rotate(-90deg);
            transform-origin: 50% 50%;
        }

        .task-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .pulse-animation {
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% {
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(79, 70, 229, 0.4);
            }
            70% {
                transform: scale(1.05);
                box-shadow: 0 0 0 10px rgba(79, 70, 229, 0);
            }
            100% {
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(79, 70, 229, 0);
            }
        }

        .floating-btn {
            box-shadow: 0 4px 14px 0 rgba(79, 70, 229, 0.4);
        }

        .quote-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.9) 0%, rgba(248,250,252,0.9) 100%);
            backdrop-filter: blur(10px);
        }

        /* Priority styles */
        .priority-low { background-color: #d1fae5; color: #065f46; } /* green-100/green-700 */
        .priority-medium { background-color: #fef3c7; color: #92400e; } /* yellow-100/yellow-800 */
        .priority-high { background-color: #fee2e2; color: #991b1b; } /* red-100/red-800 */

        /* Custom style for the task hub circle (optional, Tailwind handles most) */
        .task-hub-circle {
            min-height: 24rem; /* Ensure it's tall enough for content on smaller screens */
        }
        @media (min-width: 768px) { /* Adjust for medium screens and up */
            .task-hub-circle {
                height: 24rem; /* Fixed height for a perfect circle on larger screens */
            }
        }
    </style>
</head>
<body>
    <!-- Login Page (initially shown or hidden by JS) -->
    <div id="login-page" class="min-h-screen flex items-center justify-center bg-gray-100">
        <div class="bg-white p-8 rounded-lg shadow-xl w-full max-w-md">
            <div class="text-center mb-8">
                <i class="fas fa-graduation-cap text-indigo-600 text-5xl mb-4"></i>
                <h2 class="text-3xl font-bold text-gray-800">Welcome to StudyFocus</h2>
                <p class="text-gray-500">Sign in to manage your academic life.</p>
            </div>
            <form id="login-form" class="space-y-6">
                <div>
                    <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" id="username" name="username" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" placeholder="Enter your email" required>
                    <p id="username-error" class="text-red-500 text-xs mt-1 hidden">Please enter a valid email address.</p>
                </div>
                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <input type="password" id="password" name="password" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" placeholder="Enter your password" required>
                </div>
                <button type="submit" class="w-full bg-indigo-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-indigo-700 transition transform hover:scale-105">
                    Log In
                </button>
            </form>
            <p class="mt-6 text-center text-gray-500 text-sm">
                Don't have an account? <a href="#" class="text-indigo-600 hover:underline">Sign Up</a>
            </p>
        </div>
    </div>

    <!-- Main Content (initially hidden or shown by JS) -->
    <div id="main-content" class="hidden">
        <!-- Navigation -->
        <nav class="gradient-bg text-white shadow-lg">
            <div class="container mx-auto px-4 py-3 flex justify-between items-center">
                <div class="flex items-center space-x-2 cursor-pointer" id="studyfocus-logo">
                    <i class="fas fa-graduation-cap text-2xl"></i>
                    <span class="text-xl font-bold">StudyFocus</span>
                </div>
                <div class="hidden md:flex space-x-6">
                    <a href="#features" class="hover:text-gray-200 transition">Features</a>
                    <a href="#dashboard" class="hover:text-gray-200 transition">Dashboard</a>
                    <a href="#goals" class="hover:text-gray-200 transition">Goals</a>
                    <a href="#todo-list" class="hover:text-gray-200 transition">To-Do</a>
                    <a href="#pomodoro" class="hover:text-gray-200 transition">Pomodoro</a>
                    <a href="#analytics" class="hover:text-gray-200 transition">Analytics</a>
                </div>
                <div class="flex items-center space-x-4" id="user-area">
                    <!-- Dynamic content managed by backend.js for login/logout -->
                    <button id="theme-toggle" class="p-2 rounded-full hover:bg-indigo-700 transition">
                        <i class="fas fa-moon"></i>
                    </button>
                    <button id="nav-sign-in" class="bg-white text-indigo-600 px-4 py-2 rounded-lg font-medium hover:bg-gray-100 transition">
                        Sign In
                    </button>
                </div>
            </div>
        </nav>

        <!-- Hero Section -->
        <section class="gradient-bg text-white py-16 md:py-24">
            <div class="container mx-auto px-4 flex flex-col md:flex-row items-center">
                <div class="md:w-1/2 mb-10 md:mb-0">
                    <h1 class="text-4xl md:text-5xl font-bold mb-6">Master Your Study Habits</h1>
                    <p class="text-xl mb-8 text-indigo-100">Overcome procrastination, boost focus, and prevent burnout with our smart study companion.</p>
                </div>
                <div class="md:w-1/2 flex justify-center">
                    <div class="relative w-full max-w-md">
                        <div class="absolute -top-10 -left-10 w-32 h-32 bg-yellow-400 rounded-full opacity-20"></div>
                        <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-green-400 rounded-full opacity-20"></div>
                        <div class="relative bg-white rounded-xl shadow-2xl overflow-hidden">
                            <div class="bg-gray-100 p-3 flex items-center">
                                <div class="flex space-x-2">
                                    <div class="w-3 h-3 rounded-full bg-red-500"></div>
                                    <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                                    <div class="w-3 h-3 rounded-full bg-green-500"></div>
                                </div>
                            </div>
                            <div class="p-6">
                                <div class="flex items-center mb-6">
                                    <div class="w-12 h-12 bg-indigo-100 rounded-full flex items-center justify-center mr-4">
                                        <i class="fas fa-book text-indigo-600 text-xl"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800">Today's Study Plan</h3>
                                        <p class="text-gray-500 text-sm"><span id="tasks-remaining">3</span> tasks remaining</p>
                                    </div>
                                </div>
                                <div class="space-y-4" id="today-tasks">
                                    <div class="flex items-center bg-indigo-50 p-3 rounded-lg task-item" data-completed="false">
                                        <input type="checkbox" class="mr-3 h-5 w-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                                        <div>
                                            <p class="font-medium text-gray-800">Read Chapter 5</p>
                                            <p class="text-xs text-gray-500">History - Due Today</p>
                                        </div>
                                    </div>
                                    <div class="flex items-center bg-indigo-50 p-3 rounded-lg task-item" data-completed="false">
                                        <input type="checkbox" class="mr-3 h-5 w-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                                        <div>
                                            <p class="font-medium text-gray-800">Math Problems</p>
                                            <p class="text-xs text-gray-500">Algebra - Due Tomorrow</p>
                                        </div>
                                    </div>
                                    <div class="flex items-center bg-gray-100 p-3 rounded-lg task-item" data-completed="true">
                                        <input type="checkbox" class="mr-3 h-5 w-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" checked>
                                        <div>
                                            <p class="font-medium text-gray-500 line-through">Research Paper</p>
                                            <p class="text-xs text-gray-400">English - Completed</p>
                                        </div>
                                    </div>
                                </div>
                                </div>

                                <div class="mt-6 pt-4 border-t border-gray-200">
                                    <div class="flex justify-between items-center">
                                        <span class="text-sm font-medium text-gray-700">Progress</span>
                                        <span class="text-sm font-bold text-indigo-600" id="progress-percentage">33%</span>
                                    </div>
                                    <div class="w-full bg-gray-200 rounded-full h-2 mt-2">
                                        <div class="bg-indigo-600 h-2 rounded-full" style="width: 33%" id="progress-bar"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section id="features" class="py-16 bg-white">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <h2 class="text-3xl font-bold text-gray-800 mb-4">Features Designed for Student Success</h2>
                    <p class="text-lg text-gray-600 max-w-2xl mx-auto">Our tools help you stay organized, focused, and motivated throughout your academic journey.</p>
                </div>
                <div class="grid md:grid-cols-3 gap-8">
                    <div class="bg-gray-50 p-8 rounded-xl hover:shadow-lg transition">
                        <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mb-6">
                            <i class="fas fa-tasks text-indigo-600 text-2xl"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-3 text-gray-800">Smart Task Management</h3>
                        <p class="text-gray-600">Break down large assignments into manageable tasks with automatic scheduling based on due dates and priority.</p>
                    </div>
                    <div class="bg-gray-50 p-8 rounded-xl hover:shadow-lg transition">
                        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-6">
                            <i class="fas fa-chart-line text-green-600 text-2xl"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-3 text-gray-800">Progress Tracking</h3>
                        <p class="text-gray-600">Visualize your progress with detailed analytics and receive personalized recommendations to improve your study habits.</p>
                    </div>
                    <div class="bg-gray-50 p-8 rounded-xl hover:shadow-lg transition">
                        <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mb-6">
                            <i class="fas fa-brain text-yellow-600 text-2xl"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-3 text-gray-800">Focus Mode</h3>
                        <p class="text-gray-600">Eliminate distractions with timed focus sessions, ambient sounds, and website blockers to maximize productivity.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Dashboard Section -->
        <section id="dashboard" class="py-16 bg-gray-50">
            <div class="container mx-auto px-4">
                <div class="flex flex-col md:flex-row items-center mb-16">
                    <div class="md:w-1/2 mb-10 md:mb-0">
                        <h2 class="text-3xl font-bold text-gray-800 mb-4">Your Personal Study Dashboard</h2>
                        <p class="text-lg text-gray-600 mb-6">Get a clear overview of your academic workload, upcoming deadlines, and progress across all subjects.</p>
                        <ul class="space-y-4">
                            <li class="flex items-start">
                                <i class="fas fa-check-circle text-green-500 mt-1 mr-3"></i>
                                <span class="text-gray-700">Color-coded subjects for easy organization</span>
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check-circle text-green-500 mt-1 mr-3"></i>
                                <span class="text-gray-700">Drag-and-drop task prioritization</span>
                            </li>
                            <li class="flex items-start">
                                <i class="fas fa-check-circle text-green-500 mt-1 mr-3"></i>
                                <span class="text-gray-700">Smart notifications for approaching deadlines</span>
                            </li>
                        </ul>
                    </div>
                    <div class="md:w-1/2 md:pl-10">
                        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                            <div class="bg-gray-100 p-3 flex items-center justify-between">
                                <div class="flex space-x-2">
                                    <div class="w-3 h-3 rounded-full bg-red-500"></div>
                                    <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                                    <div class="w-3 h-3 rounded-full bg-green-500"></div>
                                </div>
                                <div class="text-sm text-gray-500">Study Dashboard</div>
                                <div class="w-6"></div>
                            </div>
                            <div class="p-6">
                                <div class="flex mb-6">
                                    <div class="w-1/2 pr-2">
                                        <div class="bg-indigo-50 p-4 rounded-lg">
                                            <h4 class="font-bold text-gray-800 mb-2">Upcoming Deadlines</h4>
                                            <div class="space-y-3">
                                                <div class="flex items-center">
                                                    <div class="w-3 h-3 bg-red-500 rounded-full mr-2"></div>
                                                    <div>
                                                        <p class="text-sm font-medium">History Essay</p>
                                                        <p class="text-xs text-gray-500">Due tomorrow</p>
                                                    </div>
                                                </div>
                                                <div class="flex items-center">
                                                    <div class="w-3 h-3 bg-yellow-500 rounded-full mr-2"></div>
                                                    <div>
                                                        <p class="text-sm font-medium">Math Quiz</p>
                                                        <p class="text-xs text-gray-500">Due in 3 days</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="w-1/2 pl-2">
                                        <div class="bg-green-50 p-4 rounded-lg">
                                            <h4 class="font-bold text-gray-800 mb-2">Recent Achievements</h4>
                                            <div class="flex items-center">
                                                <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center mr-2">
                                                    <i class="fas fa-trophy text-green-600 text-sm"></i>
                                                </div>
                                                <div>
                                                    <p class="text-sm font-medium">3-day streak!</p>
                                                    <p class="text-xs text-gray-500">Keep it up</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="bg-gray-100 rounded-lg p-4 mb-4">
                                    <h4 class="font-bold text-gray-800 mb-3">Weekly Progress</h4>
                                    <div class="flex justify-between text-xs text-gray-500 mb-2">
                                        <span>Mon</span>
                                        <span>Tue</span>
                                        <span>Wed</span>
                                        <span>Thu</span>
                                        <span>Fri</span>
                                        <span>Sat</span>
                                        <span>Sun</span>
                                    </div>
                                    <div class="flex justify-between h-32 items-end">
                                        <div class="w-8 bg-indigo-200 rounded-t-sm" style="height: 40%"></div>
                                        <div class="w-8 bg-indigo-300 rounded-t-sm" style="height: 60%"></div>
                                        <div class="w-8 bg-indigo-400 rounded-t-sm" style="height: 80%"></div>
                                        <div class="w-8 bg-indigo-500 rounded-t-sm" style="height: 30%"></div>
                                        <div class="w-8 bg-indigo-600 rounded-t-sm" style="height: 70%"></div>
                                        <div class="w-8 bg-indigo-300 rounded-t-sm" style="height: 20%"></div>
                                        <div class="w-8 bg-indigo-200 rounded-t-sm" style="height: 10%"></div>
                                    </div>
                                </div>
                                <div class="flex justify-between items-center">
                                    <button id="view-full-report" class="text-sm text-indigo-600 font-medium hover:text-indigo-800">View Full Report</button>
                                    <button id="add-task-btn" class="text-sm bg-indigo-600 text-white px-3 py-1 rounded hover:bg-indigo-700">Add Task</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Goals Section -->
        <section id="goals" class="py-16 bg-white">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <h2 class="text-3xl font-bold text-gray-800 mb-4">Set and Achieve Your Study Goals</h2>
                    <p class="text-lg text-gray-600 max-w-2xl mx-auto">Break down your academic objectives into actionable steps with our SMART goal system.</p>
                </div>
                <div class="max-w-4xl mx-auto">
                    <div class="bg-gray-50 rounded-xl p-6 mb-8">
                        <div class="flex items-center mb-6">
                            <div class="w-12 h-12 bg-indigo-100 rounded-full flex items-center justify-center mr-4">
                                <i class="fas fa-bullseye text-indigo-600 text-xl"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-800">Goal Setting</h3>
                                <p class="text-gray-500 text-sm">Create a new study goal</p>
                            </div>
                        </div>
                        <form id="goal-form" class="space-y-4">
                            <div>
                                <label for="goal-title" class="block text-sm font-medium text-gray-700 mb-1">Goal Title</label>
                                <input type="text" id="goal-title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" placeholder="e.g. Improve Calculus grade" required>
                            </div>
                            <div>
                                <label for="goal-description" class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                                <textarea id="goal-description" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" placeholder="What do you want to achieve?"></textarea>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label for="goal-subject" class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
                                    <select id="goal-subject" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" required>
                                        <option value="">Select Subject</option>
                                        <option value="math">Mathematics</option>
                                        <option value="science">Science</option>
                                        <option value="history">History</option>
                                        <option value="english">English</option>
                                        <option value="other">Other</option>
                                    </select>
                                </div>
                                <div id="other-subject-input-wrapper" class="hidden">
                                    <label for="other-subject-name" class="block text-sm font-medium text-gray-700 mb-1">Subject Name</label>
                                    <input type="text" id="other-subject-name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" placeholder="Enter subject name">
                                </div>
                                <div>
                                    <label for="goal-deadline" class="block text-sm font-medium text-gray-700 mb-1">Target Date</label>
                                    <input type="date" id="goal-deadline" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" required>
                                </div>
                            </div>
                            <div class="pt-4">
                                <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-indigo-700 transition">Create Goal</button>
                            </div>
                        </form>
                    </div>

                    <h3 class="text-xl font-bold text-gray-800 mb-6">Your Current Goals</h3>
                    <div id="goals-container" class="space-y-4">
                        <!-- Goals will be added here dynamically by backend.js -->
                    </div>
                </div>
            </div>
        </section>

        <!-- To-Do List Section -->
        <section id="todo-list" class="py-16 bg-gray-100">
            <div class="container mx-auto px-4">
                <div class="text-center mb-10">
                    <h2 class="text-3xl font-bold text-gray-800 mb-4">Your To-Do List</h2>
                    <p class="text-lg text-gray-600 max-w-2xl mx-auto">Organize your tasks, set priorities, and crush your academic workload.</p>
                </div>

                <div class="max-w-3xl mx-auto flex justify-center mb-12">
                    <div class="task-hub-circle relative w-full h-auto py-10 rounded-xl flex flex-col items-center justify-center p-8 text-center bg-gradient-to-br from-indigo-50 to-purple-100 shadow-xl overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-br from-indigo-50 to-purple-100 opacity-80 rounded-xl z-0"></div>
                        <div class="relative z-10 w-full">
                            <i class="fas fa-brain text-indigo-600 text-4xl mb-4 opacity-75"></i>
                            <h3 class="font-bold text-gray-800 text-xl mb-4">Add a New Task</h3>
                            <form id="task-form" class="space-y-3 w-full max-w-md mx-auto">
                                <div>
                                    <input type="text" id="task-title" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500 bg-white bg-opacity-80 placeholder-gray-500 text-lg" placeholder="Task Title (e.g. Finish History Essay)" required>
                                </div>
                                <div>
                                    <textarea id="task-description" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500 bg-white bg-opacity-80 placeholder-gray-500 text-lg" placeholder="Description (Optional)"></textarea>
                                </div>
                                <div class="pt-2">
                                    <button type="submit" class="bg-indigo-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-indigo-700 transition w-full text-lg">Add Task</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <h3 class="text-xl font-bold text-gray-800 mb-6 max-w-4xl mx-auto">Your Current Tasks</h3>
                <div id="tasks-container" class="space-y-4 max-w-4xl mx-auto">
                    <!-- Tasks will be rendered here dynamically -->
                </div>
            </div>
        </section>

        <!-- Pomodoro Timer Section -->
        <section id="pomodoro" class="py-16 bg-gray-100">
            <div class="container mx-auto px-4">
                <div class="text-center mb-10">
                    <h2 class="text-3xl font-bold text-gray-800 mb-4">Pomodoro Timer</h2>
                    <p class="text-lg text-gray-600 max-w-2xl mx-auto">Boost your productivity with focused work intervals and regular breaks.</p>
                </div>
                <div class="max-w-xl mx-auto bg-white rounded-xl shadow-lg p-8">
                    <div class="flex justify-center items-center mb-6">
                        <div class="w-48 h-48 rounded-full bg-indigo-50 flex items-center justify-center text-indigo-600 relative">
                            <svg class="progress-ring absolute w-full h-full" width="100%" height="100%">
                                <circle class="progress-ring__circle" stroke="#4f46e5" stroke-width="8" fill="transparent" r="88" cx="96" cy="96" style="stroke-dasharray: 553; stroke-dashoffset: 553;"></circle>
                            </svg>
                            <span id="time-display" class="text-5xl font-bold">25:00</span>
                        </div>
                    </div>
                    <div class="flex justify-center space-x-4 mb-6">
                        <button id="start-timer" class="bg-green-500 text-white px-6 py-3 rounded-lg font-bold hover:bg-green-600 transition">
                            <i class="fas fa-play mr-2"></i>Start
                        </button>
