    <script>
        // backend.js
        // Handles login/logout + full goals CRUD (Create, Read, Update, Delete) with localStorage fallback.

        document.addEventListener('DOMContentLoaded', () => {

            /* ---------------- INITIAL DATA (Goals) ---------------- */
            const initialGoals = [
                {
                  "id": "1",
                  "title": "Improve Calculus grade from B to A",
                  "description": "Complete all practice problems weekly and attend professor's office hours twice a month.",
                  "subject": "Mathematics",
                  "deadline": "2023-05-15",
                  "status": "Active",
                  "progress": 45
                },
                {
                  "id": "2",
                  "title": "Read 20 academic papers this semester",
                  "description": "Read and summarize 2 papers per week, focusing on methodology sections.",
                  "subject": "Research Methods",
                  "deadline": "2023-12-10",
                  "status": "On Track",
                  "progress": 70
                }
            ];

            if (!localStorage.getItem('cachedGoals')) {
                localStorage.setItem('cachedGoals', JSON.stringify(initialGoals));
            }

            /* ---------------- INITIAL DATA (Tasks) ---------------- */
            const initialTasks = [
                {
                    "id": 101,
                    "title": "Finish English Essay Draft",
                    "description": "Write at least 1000 words for the argument essay on 'Climate Change Impact'.",
                    "completed": false,
                    "addedDate": "2023-10-20T10:00:00Z"
                },
                {
                    "id": 102,
                    "title": "Review Biology Chapter 3",
                    "description": "Go over notes and textbook for the upcoming midterm.",
                    "completed": true,
                    "addedDate": "2023-10-18T14:30:00Z",
                    "completedDate": "2023-10-21T09:00:00Z"
                },
                {
                    "id": 103,
                    "title": "Solve Practice Math Problems",
                    "description": "Complete exercises 5-10 from the advanced algebra textbook.",
                    "completed": false,
                    "addedDate": "2023-10-22T11:00:00Z"
                },
                {
                    "id": 104,
                    "title": "Prepare for Chemistry Lab",
                    "description": "Read the lab manual and understand the procedure for experiment #5.",
                    "completed": false,
                    "addedDate": "2023-10-23T16:00:00Z"
                }
            ];

            if (!localStorage.getItem('cachedTasks')) {
                localStorage.setItem('cachedTasks', JSON.stringify(initialTasks));
            }


          /* ---------------- MOTIVATIONAL QUOTE LOGIC ---------------- */
            const motivationalQuotes = [
                { quote: "The secret to getting ahead is getting started.", author: "Mark Twain" },
                { quote: "Don't watch the clock; do what it does. Keep going.", author: "Sam Levenson" },
                { quote: "The expert in anything was once a beginner.", author: "Helen Hayes" },
                { quote: "The only way to do great work is to love what you do.", author: "Steve Jobs" },
                { quote: "Success is not final, failure is not fatal: it is the courage to continue that counts.", author: "Winston Churchill" },
                { quote: "Believe you can and you're halfway there.", author: "Theodore Roosevelt" }
            ];

            const quoteModal = document.getElementById('quote-modal');
            const quoteText = document.getElementById('quote-text');
            const quoteAuthor = document.getElementById('quote-author');
            const closeQuoteModalBtn = document.getElementById('close-quote-modal');

            function showMotivationalQuote() {
                const randomIndex = Math.floor(Math.random() * motivationalQuotes.length);
                const randomQuote = motivationalQuotes[randomIndex];

                quoteText.textContent = randomQuote.quote;
                quoteAuthor.textContent = `- ${randomQuote.author}`;

                if (quoteModal) {
                    quoteModal.classList.remove('hidden');
                }
            }

            if (closeQuoteModalBtn) {
                closeQuoteModalBtn.addEventListener('click', () => {
                    if (quoteModal) {
                        quoteModal.classList.add('hidden');
                    }
                });
            }

          /* ---------------- LOGIN + USER LOGIC ---------------- */

          const loginPage = document.getElementById('login-page');
          const mainContent = document.getElementById('main-content');
          const displayName = document.getElementById('displayName');
          const userArea = document.getElementById('user-area');
          const loginForm = document.getElementById('login-form');
          const usernameInput = document.getElementById('username');
          const usernameError = document.getElementById('username-error');

          function isValidEmail(email) {
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            return emailRegex.test(email);
          }

          function updateUserUI(username) {
            if (displayName) displayName.textContent = username;
            if (userArea) {
              userArea.innerHTML = `
                <span class="font-semibold text-white mr-2" id="loggedInUserName">${username}</span>
                <button id="logout" class="bg-white text-indigo-600 px-4 py-2 rounded-lg font-medium hover:bg-gray-100 transition">
                  Logout
                </button>
              `;
            }
          }

          const savedUser = localStorage.getItem('studyfocusUser');
          if (savedUser && loginPage && mainContent) {
            loginPage.classList.add('hidden');
            mainContent.classList.remove('hidden');
            updateUserUI(savedUser);
          } else if (loginPage && mainContent) {
            loginPage.classList.remove('hidden');
            mainContent.classList.add('hidden');
          }


          if (loginForm) {
            loginForm.addEventListener('submit', (e) => {
              e.preventDefault();
              const username = usernameInput.value.trim();
              const password = document.getElementById('password').value.trim();

              if (!isValidEmail(username)) {
                usernameError.classList.remove('hidden');
                return;
              } else {
                usernameError.classList.add('hidden');
              }

              if (!username || !password) {
                alert('Please fill out both fields.');
                return;
              }
              // Simple authentication: any non-empty username/password will "log in"
              localStorage.setItem('studyfocusUser', username);
              updateUserUI(username);

              if (loginPage && mainContent) {
                loginPage.classList.add('hidden');
                mainContent.classList.remove('hidden');
              }
              showMotivationalQuote(); // Show quote on login
              fetchGoals();
              fetchTasks(); // Fetch tasks after login
              initStudyChart(); // Initialize chart after login
            });
          }

          document.addEventListener('click', (e) => {
            if (e.target && e.target.id === 'logout') {
              localStorage.removeItem('studyfocusUser');
              if (mainContent && loginPage) {
                mainContent.classList.add('hidden');
                loginPage.classList.remove('hidden');
                const navUserArea = document.getElementById('user-area');
                if (navUserArea) {
                    navUserArea.innerHTML = `
                        <button id="theme-toggle" class="p-2 rounded-full hover:bg-indigo-700 transition">
                            <i class="fas fa-moon"></i>
                        </button>
                        <button id="nav-sign-in" class="bg-white text-indigo-600 px-4 py-2 rounded-lg font-medium hover:bg-gray-100 transition">
                            Sign In
                        </button>
                    `;
                }
              }
            } else if (e.target && e.target.id === 'nav-sign-in') {
                if (loginPage && mainContent) {
                    mainContent.classList.add('hidden');
                    loginPage.classList.remove('hidden');
                }
            } else if (e.target && e.target.id === 'studyfocus-logo') {
                localStorage.removeItem('studyfocusUser'); // Remove user to force login screen
                location.reload(); // Refresh the page
            } else if (e.target && e.target.id === 'view-full-report') {
                document.getElementById('analytics').scrollIntoView({ behavior: 'smooth' });
            } else if (e.target && e.target.id === 'add-task-btn') {
                document.getElementById('todo-list').scrollIntoView({ behavior: 'smooth' });
                document.getElementById('task-title').focus(); // Focus on the task title input
            }
          });


          /* ---------------- TODAY'S PLAN INTERACTION ---------------- */
            const todayTasksContainer = document.getElementById('today-tasks');
            const tasksRemainingSpan = document.getElementById('tasks-remaining');
            const progressBar = document.getElementById('progress-bar');
            const progressPercentage = document.getElementById('progress-percentage');

            function updateProgress() {
                const totalTasks = todayTasksContainer.children.length;
                const completedTasks = Array.from(todayTasksContainer.children).filter(task => task.dataset.completed === 'true').length;
                const remainingTasks = totalTasks - completedTasks;
                const percentage = totalTasks > 0 ? Math.round((completedTasks / totalTasks) * 100) : 0;

                tasksRemainingSpan.textContent = remainingTasks;
                progressBar.style.width = `${percentage}%`;
                progressPercentage.textContent = `${percentage}%`;
            }

            if (todayTasksContainer) {
                todayTasksContainer.addEventListener('change', (e) => {
                    if (e.target.type === 'checkbox') {
                        const taskItem = e.target.closest('.task-item');
                        const taskText = taskItem.querySelector('p:first-child');
                        const subText = taskItem.querySelector('p:last-child');

                        if (e.target.checked) {
                            taskItem.dataset.completed = 'true';
                            taskText.classList.add('line-through', 'text-gray-500');
                            subText.classList.add('text-gray-400');
                            taskItem.classList.remove('bg-indigo-50');
                            taskItem.classList.add('bg-gray-100');
                        } else {
                            taskItem.dataset.completed = 'false';
                            taskText.classList.remove('line-through', 'text-gray-500');
                            subText.classList.remove('text-gray-400');
                            taskItem.classList.remove('bg-gray-100');
                            taskItem.classList.add('bg-indigo-50');
                        }
                        updateProgress();
                    }
                });
            }
            updateProgress(); // Initial progress calculation on load


          /* ---------------- GOALS SYSTEM WITH LOCALSTORAGE ---------------- */

          const goalsContainer = document.getElementById('goals-container');
          const goalForm = document.getElementById('goal-form');
          const editModal = document.getElementById('edit-modal');
          const editForm = document.getElementById('edit-form');
          const cancelEditBtn = document.getElementById('cancel-edit');
          const goalSubjectSelect = document.getElementById('goal-subject');
          const otherSubjectInputWrapper = document.getElementById('other-subject-input-wrapper');
          const otherSubjectNameInput = document.getElementById('other-subject-name');

          const editSubjectSelect = document.getElementById('edit-subject');
          const editOtherSubjectInputWrapper = document.getElementById('edit-other-subject-input-wrapper');
          const editOtherSubjectNameInput = document.getElementById('edit-other-subject-name');
          const editProgressInput = document.getElementById('edit-progress');


          let goals = JSON.parse(localStorage.getItem('cachedGoals') || '[]');

          function saveGoals() {
            localStorage.setItem('cachedGoals', JSON.stringify(goals));
          }

          function escapeHtml(s) {
            if (!s && s !== 0) return '';
            return String(s)
              .replaceAll('&', '&amp;')
              .replaceAll('<', '&lt;')
              .replaceAll('>', '&gt;')
              .replaceAll('"', '&quot;')
              .replaceAll("'", '&#39;');
          }

          function renderGoalCard(goal) {
            const card = document.createElement('div');
            card.className = 'goal-card bg-white border border-gray-200 rounded-xl p-5 shadow-sm hover:shadow-md transition';
            const statusColor = goal.status === 'On Track' ? 'bg-green-100 text-green-800' : 'bg-indigo-100 text-indigo-800';
            const displaySubject = goal.subject === 'other' ? goal.customSubjectName : goal.subject;

            card.innerHTML = `
              <div class="flex justify-between items-start mb-3">
                <div>
                  <h4 class="font-bold text-gray-800">${escapeHtml(goal.title)}</h4>
                  <p class="text-sm text-gray-500">${escapeHtml(displaySubject || '')}</p>
                </div>
                <span class="${statusColor} text-xs px-2 py-1 rounded">${escapeHtml(goal.status || 'Active')}</span>
              </div>
              <p class="text-gray-600 mb-4">${escapeHtml(goal.description || '')}</p>
              <div class="flex justify-between items-center mb-4">
                <div>
                  <span class="text-xs font-medium text-gray-500">Target: ${escapeHtml(goal.deadline || '—')}</span>
                </div>
                <div class="flex items-center">
                  <div class="w-24 h-2 bg-gray-200 rounded-full mr-2">
                    <div class="h-2 bg-green-500 rounded-full" style="width: ${Number(goal.progress || 0)}%"></div>
                  </div>
                  <span class="text-xs font-bold text-gray-700">${Number(goal.progress || 0)}%</span>
                </div>
              </div>
              <div class="flex space-x-2">
                <button onclick="editGoal(${goal.id})" class="px-3 py-1 text-sm bg-yellow-400 text-white rounded hover:bg-yellow-500">Edit</button>
                <button onclick="deleteGoal(${goal.id})" class="px-3 py-1 text-sm bg-red-500 text-white rounded hover:bg-red-600">Delete</button>
              </div>
            `;
            return card;
          }

          function renderGoals() {
            if (!goalsContainer) return;
            goalsContainer.innerHTML = '';
            if (goals.length === 0) {
              goalsContainer.innerHTML = '<div class="text-gray-500">No goals found.</div>';
              return;
            }
            goals.forEach(goal => goalsContainer.appendChild(renderGoalCard(goal)));
          }

          /* ---------------- FETCH GOALS FROM LOCALSTORAGE ---------------- */
          function fetchGoals() {
            goals = JSON.parse(localStorage.getItem('cachedGoals') || '[]');
            renderGoals();
          }

          /* ---------------- 'Other' Subject Input Logic ---------------- */
            if (goalSubjectSelect) {
                goalSubjectSelect.addEventListener('change', () => {
                    if (goalSubjectSelect.value === 'other') {
                        otherSubjectInputWrapper.classList.remove('hidden');
                        otherSubjectNameInput.setAttribute('required', 'true');
                    } else {
                        otherSubjectInputWrapper.classList.add('hidden');
                        otherSubjectNameInput.removeAttribute('required');
                        otherSubjectNameInput.value = '';
                    }
                });
            }

            if (editSubjectSelect) {
                editSubjectSelect.addEventListener('change', () => {
                    if (editSubjectSelect.value === 'other') {
                        editOtherSubjectInputWrapper.classList.remove('hidden');
                        editOtherSubjectNameInput.setAttribute('required', 'true');
                    } else {
                        editOtherSubjectInputWrapper.classList.add('hidden');
                        editOtherSubjectNameInput.removeAttribute('required');
                        editOtherSubjectNameInput.value = '';
                    }
                });
            }


          /* ---------------- CREATE GOAL ---------------- */
          if (goalForm) {
            goalForm.addEventListener('submit', (ev) => {
              ev.preventDefault();
              const title = document.getElementById('goal-title').value.trim();
              const description = document.getElementById('goal-description').value.trim();
              let subject = goalSubjectSelect.value;
              let customSubjectName = '';

              if (subject === 'other') {
                customSubjectName = otherSubjectNameInput.value.trim();
                if (!customSubjectName) {
                    alert('Please enter a subject name for "Other".');
                    return;
                }
              }

              const deadline = document.getElementById('goal-deadline').value;

              if (!title || !subject || !deadline || (subject === 'other' && !customSubjectName)) {
                alert('Please fill all required fields!');
                return;
              }

              const newGoal = {
                id: Date.now(),
                title,
                description,
                subject,
                customSubjectName: subject === 'other' ? customSubjectName : undefined, // Only save if 'other'
                deadline,
                progress: 0,
                status: 'Active',
              };

              goals.unshift(newGoal);
              saveGoals();
              renderGoals();
              goalForm.reset();
              otherSubjectInputWrapper.classList.add('hidden'); // Hide after submission
              otherSubjectNameInput.value = '';
            });
          }

          /* ---------------- EDIT GOAL ---------------- */
          window.editGoal = (id) => {
            const goal = goals.find(g => g.id == id);
            if (!goal) return;

            document.getElementById('edit-id').value = goal.id;
            document.getElementById('edit-title').value = goal.title;
            document.getElementById('edit-description').value = goal.description;
            document.getElementById('edit-deadline').value = goal.deadline;
            document.getElementById('edit-progress').value = goal.progress; // Set progress value

            editSubjectSelect.value = goal.subject;
            if (goal.subject === 'other') {
                editOtherSubjectInputWrapper.classList.remove('hidden');
                editOtherSubjectNameInput.value = goal.customSubjectName || '';
                editOtherSubjectNameInput.setAttribute('required', 'true');
            } else {
                editOtherSubjectInputWrapper.classList.add('hidden');
                editOtherSubjectNameInput.removeAttribute('required');
                editOtherSubjectNameInput.value = '';
            }

            editModal.classList.remove('hidden');
            editModal.classList.add('flex');
          };

          editForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const id = document.getElementById('edit-id').value;
            const title = document.getElementById('edit-title').value.trim();
            const description = document.getElementById('edit-description').value.trim();
            let subject = editSubjectSelect.value;
            let customSubjectName = '';
            const progress = parseInt(document.getElementById('edit-progress').value); // Get progress value

            if (subject === 'other') {
                customSubjectName = editOtherSubjectNameInput.value.trim();
                if (!customSubjectName) {
                    alert('Please enter a subject name for "Other".');
                    return;
                }
            }

            const deadline = document.getElementById('edit-deadline').value;

            const index = goals.findIndex(g => g.id == id);
            if (index === -1) return;

            const updatedGoal = {
                ...goals[index],
                title,
                description,
                subject,
                customSubjectName: subject === 'other' ? customSubjectName : undefined, // Only save if 'other'
                deadline,
                progress // Update progress
            };
            goals[index] = updatedGoal;
            saveGoals();
            renderGoals();
            editModal.classList.add('hidden');
          });

          cancelEditBtn.addEventListener('click', () => editModal.classList.add('hidden'));

          /* ---------------- DELETE GOAL ---------------- */
          window.deleteGoal = (id) => {
            if (!confirm('Are you sure you want to delete this goal?')) return;
            goals = goals.filter(g => g.id != id);
            saveGoals();
            renderGoals();
          };

          /* ---------------- WEEKLY STUDY DISTRIBUTION CHART (Chart.js) ---------------- */
            let studyChart;
            function initStudyChart() {
                const ctx = document.getElementById('studyChart');
                if (!ctx) return; // Ensure canvas exists

                // Aggregate data from completed tasks and goals
                const dailyCompletionData = {
                    'Mon': 0, 'Tue': 0, 'Wed': 0, 'Thu': 0, 'Fri': 0, 'Sat': 0, 'Sun': 0
                };
                const dayMap = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

                // Tasks data (assuming tasks have a `completedDate` or similar for more accurate tracking)
                tasks.forEach(task => {
                    if (task.completed && task.completedDate) { // Assuming a completedDate property exists
                        const taskDate = new Date(task.completedDate);
                        const today = new Date();
                        const diffTime = Math.abs(today - taskDate);
                        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                        if (diffDays <= 7) {
                            const dayOfWeek = dayMap[taskDate.getDay()];
                            dailyCompletionData[dayOfWeek]++;
                        }
                    }
                });

                // Goals data (if a goal has an explicit completion date or milestone)
                // For simplicity, let's assume a completed goal adds a significant "study event"
                goals.forEach(goal => {
                    if (goal.progress >= 100 && goal.completionDate) { // Assuming a completionDate property
                        const goalDate = new Date(goal.completionDate);
                        const today = new Date();
                        const diffTime = Math.abs(today - goalDate);
                        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                        if (diffDays <= 7) {
                            const dayOfWeek = dayMap[goalDate.getDay()];
                            dailyCompletionData[dayOfWeek] += 3; // Goals contribute more "study"
                        }
                    }
                });

                const data = {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Study Efforts (Tasks + Goals)',
                        data: Object.values(dailyCompletionData),
                        backgroundColor: 'rgba(79, 70, 229, 0.8)', // indigo-600
                        borderColor: 'rgba(79, 70, 229, 1)',
                        borderWidth: 1,
                        borderRadius: 4,
                    }]
                };

                const config = {
                    type: 'bar',
                    data: data,
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false,
                            },
                            title: {
                                display: false,
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                title: {
                                    display: true,
                                    text: 'Effort Units' // Changed from Hours, as it's a combined metric
                                }
                            },
                            x: {
                                grid: {
                                    display: false
                                }
                            }
                        }
                    }
                };

                if (studyChart) {
                    studyChart.destroy(); // Destroy previous chart instance if it exists
                }
                studyChart = new Chart(ctx, config);
            }

            /* ---------------- POMODORO TIMER ---------------- */
            const timeDisplay = document.getElementById('time-display');
            const startBtn = document.getElementById('start-timer');
            const pauseBtn = document.getElementById('pause-timer');
            const resetBtn = document.getElementById('reset-timer');
            const timerStatus = document.getElementById('timer-status');
            const progressRing = document.querySelector('.progress-ring__circle');
            const radius = progressRing ? progressRing.r.baseVal.value : 88; // Default if not found
            const circumference = radius * 2 * Math.PI;
            const alarmSound = document.getElementById('alarm-sound');

            if (progressRing) {
                progressRing.style.strokeDasharray = `${circumference} ${circumference}`;
                progressRing.style.strokeDashoffset = circumference;
            }

            let timer;
            let totalSeconds;
            let secondsRemaining;
            let isPaused = true;
            let currentPhase = 'focus'; // 'focus', 'short-break', 'long-break'
            let pomodoroCount = 0; // To track for long breaks

            const studyTimeInput = document.getElementById('study-time');
            const shortBreakInput = document.getElementById('short-break');
            const longBreakInput = document.getElementById('long-break');

            let STUDY_DURATION = parseInt(studyTimeInput.value) * 60;
            let SHORT_BREAK_DURATION = parseInt(shortBreakInput.value) * 60;
            let LONG_BREAK_DURATION = parseInt(longBreakInput.value) * 60;

            function updateTimerVariables() {
                STUDY_DURATION = parseInt(studyTimeInput.value) * 60;
                SHORT_BREAK_DURATION = parseInt(shortBreakInput.value) * 60;
                LONG_BREAK_DURATION = parseInt(longBreakInput.value) * 60;
            }

            if (studyTimeInput) {
                studyTimeInput.addEventListener('change', () => {
                    updateTimerVariables();
                    if (currentPhase === 'focus' && isPaused) setTime(STUDY_DURATION);
                });
            }
            if (shortBreakInput) {
                shortBreakInput.addEventListener('change', () => {
                    updateTimerVariables();
                    if (currentPhase === 'short-break' && isPaused) setTime(SHORT_BREAK_DURATION);
                });
            }
            if (longBreakInput) {
                longBreakInput.addEventListener('change', () => {
                    updateTimerVariables();
                    if (currentPhase === 'long-break' && isPaused) setTime(LONG_BREAK_DURATION);
                });
            }


            function setProgress(percent) {
                if (progressRing) {
                    const offset = circumference - percent / 100 * circumference;
                    progressRing.style.strokeDashoffset = offset;
                }
            }

            function updateDisplay() {
                const minutes = Math.floor(secondsRemaining / 60);
                const seconds = secondsRemaining % 60;
                timeDisplay.textContent = `${minutes < 10 ? '0' : ''}${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;

                const progressPercent = ((totalSeconds - secondsRemaining) / totalSeconds) * 100;
                setProgress(progressPercent);
            }

            function setTime(duration) {
                totalSeconds = duration;
                secondsRemaining = duration;
                updateDisplay();
            }

            function startTimer() {
                isPaused = false;
                startBtn.classList.add('hidden');
                pauseBtn.classList.remove('hidden');

                timer = setInterval(() => {
                    if (secondsRemaining > 0) {
                        secondsRemaining--;
                        updateDisplay();
                    } else {
                        clearInterval(timer);

                        if(alarmSound) {
                            alarmSound.play();
                        }

                        alert('Time is up!');

                        if (currentPhase === 'focus') {
                            pomodoroCount++;
                            if (pomodoroCount % 4 === 0) {
                                currentPhase = 'long-break';
                                setTime(LONG_BREAK_DURATION);
                                timerStatus.textContent = 'Long Break';
                            } else {
                                currentPhase = 'short-break';
                                setTime(SHORT_BREAK_DURATION);
                                timerStatus.textContent = 'Short Break';
                            }
                        } else { // It was a break, go back to focus
                            currentPhase = 'focus';
                            setTime(STUDY_DURATION);
                            timerStatus.textContent = 'Focus Time';
                        }
                        startTimer(); // Automatically start next phase
                    }
                }, 1000);
            }

            function pauseTimer() {
                isPaused = true;
                clearInterval(timer);
                startBtn.classList.remove('hidden');
                pauseBtn.classList.add('hidden');
            }

            function resetTimer() {
                pauseTimer(); // Stop any running timer
                currentPhase = 'focus';
                pomodoroCount = 0;
                setTime(STUDY_DURATION);
                timerStatus.textContent = 'Focus Time';
                startBtn.classList.remove('hidden');
                pauseBtn.classList.add('hidden');
            }

            if (startBtn) startBtn.addEventListener('click', startTimer);
            if (pauseBtn) pauseBtn.addEventListener('click', pauseTimer);
            if (resetBtn) resetBtn.addEventListener('click', resetTimer);

            // Initial setup for pomodoro
            if (timeDisplay) setTime(STUDY_DURATION);


            /* ---------------- TO-DO LIST FUNCTIONALITY ---------------- */
            const tasksContainer = document.getElementById('tasks-container');
            const taskForm = document.getElementById('task-form');
            const editTaskModal = document.getElementById('edit-task-modal');
            const editTaskForm = document.getElementById('edit-task-form');
            const cancelEditTaskBtn = document.getElementById('cancel-edit-task');

            let tasks = JSON.parse(localStorage.getItem('cachedTasks') || '[]');

            function saveTasks() {
                localStorage.setItem('cachedTasks', JSON.stringify(tasks));
                initStudyChart(); // Update chart whenever tasks are saved
            }

            // Removed getPriorityClass since priority is removed from task input

            function renderTaskCard(task) {
                const card = document.createElement('div');
                card.className = `task-card bg-white border border-gray-200 rounded-xl p-5 shadow-sm hover:shadow-md transition ${task.completed ? 'opacity-70' : ''}`;

                // Removed priority class

                card.innerHTML = `
                    <div class="flex items-start justify-between mb-3">
                        <div class="flex items-center">
                            <input type="checkbox" data-task-id="${task.id}" ${task.completed ? 'checked' : ''} class="mr-3 h-5 w-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                            <div>
                                <h4 class="font-bold text-gray-800 ${task.completed ? 'line-through text-gray-500' : ''}">${escapeHtml(task.title)}</h4>
                                ${task.description ? `<p class="text-sm text-gray-600 ${task.completed ? 'line-through text-gray-400' : ''}">${escapeHtml(task.description)}</p>` : ''}
                            </div>
                        </div>
                        <!-- Removed priority display -->
                    </div>
                    <div class="flex justify-end items-center space-x-2"> <!-- Adjusted for missing due date and priority -->
                        <button onclick="editTask(${task.id})" class="px-3 py-1 text-sm bg-yellow-400 text-white rounded hover:bg-yellow-500">Edit</button>
                        <button onclick="deleteTask(${task.id})" class="px-3 py-1 text-sm bg-red-500 text-white rounded hover:bg-red-600">Delete</button>
                    </div>
                `;
                return card;
            }

            function renderTasks() {
                if (!tasksContainer) return;
                tasksContainer.innerHTML = '';
                if (tasks.length === 0) {
                    tasksContainer.innerHTML = '<div class="text-gray-500">No tasks found. Add a new task above!</div>';
                    return;
                }
                tasks.forEach(task => tasksContainer.appendChild(renderTaskCard(task)));
            }

            function fetchTasks() {
                tasks = JSON.parse(localStorage.getItem('cachedTasks') || '[]');
                renderTasks();
            }

            if (taskForm) {
                taskForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    const title = document.getElementById('task-title').value.trim();
                    const description = document.getElementById('task-description').value.trim();
                    // Removed dueDate and priority from here

                    if (!title) { // Only title is required now
                        alert('Please fill out the task title.');
                        return;
                    }

                    const newTask = {
                        id: Date.now(),
                        title,
                        description,
                        // Removed dueDate and priority from new task object
                        completed: false,
                        addedDate: new Date().toISOString() // Add addedDate for tracking
                    };

                    tasks.unshift(newTask); // Add to the beginning
                    saveTasks();
                    renderTasks();
                    taskForm.reset();
                });
            }

            // Toggle task completion
            if (tasksContainer) {
                tasksContainer.addEventListener('change', (e) => {
                    if (e.target.type === 'checkbox' && e.target.dataset.taskId) {
                        const taskId = parseInt(e.target.dataset.taskId);
                        const taskIndex = tasks.findIndex(t => t.id === taskId);
                        if (taskIndex > -1) {
                            tasks[taskIndex].completed = e.target.checked;
                            if (e.target.checked) {
                                tasks[taskIndex].completedDate = new Date().toISOString(); // Record completion date
                            } else {
                                delete tasks[taskIndex].completedDate; // Remove completion date if unchecked
                            }
                            saveTasks();
                            renderTasks(); // Re-render to update styling
                        }
                    }
                });
            }


            // Edit Task
            window.editTask = (id) => {
                const task = tasks.find(t => t.id === id);
                if (!task) return;

                document.getElementById('edit-task-id').value = task.id;
                document.getElementById('edit-task-title').value = task.title;
                document.getElementById('edit-task-description').value = task.description;
                // Removed due date and priority from edit task modal fields

                editTaskModal.classList.remove('hidden');
                editTaskModal.classList.add('flex');
            };

            if (editTaskForm) {
                editTaskForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    const id = parseInt(document.getElementById('edit-task-id').value);
                    const title = document.getElementById('edit-task-title').value.trim();
                    const description = document.getElementById('edit-task-description').value.trim();
                    // Removed dueDate and priority from edit form submission

                    const taskIndex = tasks.findIndex(t => t.id === id);
                    if (taskIndex === -1) return;

                    tasks[taskIndex] = { ...tasks[taskIndex], title, description }; // Update only title and description
                    saveTasks();
                    renderTasks();
                    editTaskModal.classList.add('hidden');
                });
            }

            if (cancelEditTaskBtn) {
                cancelEditTaskBtn.addEventListener('click', () => editTaskModal.classList.add('hidden'));
            }

            // Delete Task
            window.deleteTask = (id) => {
                if (!confirm('Are you sure you want to delete this task?')) return;
                tasks = tasks.filter(t => t.id !== id);
                saveTasks();
                renderTasks();
            };


          // Initial fetches if user is logged in
          if (savedUser) {
            fetchGoals();
            fetchTasks(); // Fetch tasks on login
            initStudyChart(); // Initialize chart on login
          }
        });
    </script>
</body>
</html>
